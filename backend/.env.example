# Database (SQLite for dev, PostgreSQL for production)
# DATABASE_URL=sqlite:///./rapidcover.db
DATABASE_URL=postgresql://postgres:password@localhost:5432/rapidcover

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# External APIs
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key
CPCB_API_KEY=your-cpcb-aqi-api-key
NEWS_API_KEY=your-news-api-key

# Razorpay (Test Mode)
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
RAZORPAY_ACCOUNT_NUMBER=x_account_number

# Twilio (for SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# App Settings
DEBUG=true
ENVIRONMENT=development

# Zero-Touch Automation
AUTO_PAYOUT_ENABLED=false  # Set to true for demo mode to auto-pay approved claims

# Web Push Notifications (VAPID)
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_CLAIM_EMAIL=mailto:admin@rapidcover.in
